---
---

<section id="contact">
  <hr class="divider" />
  <div class="container contact-inner">
    <div class="contact-left">
      <p class="section-label">Contact</p>
      <h2>Let's Work<br />Together</h2>
      <p class="contact-description">
        Available for directing projects, VFX compositing work,
        and collaborations. Feel free to reach out.
      </p>
    </div>

    <div class="contact-right">
      <div class="contact-links">
        <a href="mailto:your@email.com" class="contact-item">
          <span class="contact-type">Email</span>
          <span class="contact-value">your@email.com</span>
          <span class="arrow">→</span>
        </a>

        <a href="https://www.imdb.com/" target="_blank" rel="noopener noreferrer" class="contact-item">
          <span class="contact-type">IMDb</span>
          <span class="contact-value">Laura Alvarez</span>
          <span class="arrow">→</span>
        </a>

        <a href="https://www.linkedin.com/" target="_blank" rel="noopener noreferrer" class="contact-item">
          <span class="contact-type">LinkedIn</span>
          <span class="contact-value">lauraalvarez</span>
          <span class="arrow">→</span>
        </a>

        <a href="https://vimeo.com/" target="_blank" rel="noopener noreferrer" class="contact-item">
          <span class="contact-type">Vimeo</span>
          <span class="contact-value">lauraalvarez</span>
          <span class="arrow">→</span>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-inner {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 5rem;
    align-items: start;
  }

  h2 {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 300;
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin-top: 1rem;
    margin-bottom: 1.5rem;
  }

  .contact-description {
    color: var(--muted);
    max-width: 320px;
    line-height: 1.8;
  }

  .contact-links {
    display: flex;
    flex-direction: column;
    border-top: 1px solid var(--border);
    margin-top: 1rem;
  }

  .contact-item {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--border);
    transition: padding-left 0.2s;
  }

  .contact-item:hover {
    padding-left: 0.5rem;
  }

  .contact-item:hover .arrow {
    color: var(--accent);
  }

  .contact-type {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    color: var(--muted);
    text-transform: uppercase;
    min-width: 80px;
  }

  .contact-value {
    flex: 1;
    font-size: 0.95rem;
  }

  .arrow {
    color: var(--muted);
    font-size: 1rem;
    transition: color 0.2s;
  }

  @media (max-width: 768px) {
    .contact-inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }
</style>
