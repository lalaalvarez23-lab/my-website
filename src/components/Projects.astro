---
const projects = [
  {
    title: 'Project Title',
    category: 'Direction · Short Film',
    year: '2024',
    description:
      'Brief description of the project — what it was, your role, and what made it interesting.',
    image: '',        // add image path here, e.g. '/images/project-1.jpg'
    link: '#',        // add URL to project, video, or case study
  },
  {
    title: 'Project Title',
    category: 'VFX Compositing',
    year: '2023',
    description:
      'Brief description of the project — what it was, your role, and what made it interesting.',
    image: '',
    link: '#',
  },
  {
    title: 'Project Title',
    category: 'Direction · Commercial',
    year: '2023',
    description:
      'Brief description of the project — what it was, your role, and what made it interesting.',
    image: '',
    link: '#',
  },
  {
    title: 'Project Title',
    category: 'Architecture · Visualization',
    year: '2022',
    description:
      'Brief description of the project — what it was, your role, and what made it interesting.',
    image: '',
    link: '#',
  },
];
---

<section id="projects">
  <hr class="divider" />
  <div class="container">
    <p class="section-label">Selected Work</p>
    <h2>Projects</h2>

    <div class="project-grid">
      {projects.map((project, i) => (
        <a href={project.link} class="project-card" target="_blank" rel="noopener noreferrer">
          <div class="project-image">
            {project.image
              ? <img src={project.image} alt={project.title} />
              : <div class="image-placeholder">
                  <span>{String(i + 1).padStart(2, '0')}</span>
                </div>
            }
          </div>
          <div class="project-info">
            <div class="project-meta">
              <span class="category">{project.category}</span>
              <span class="year">{project.year}</span>
            </div>
            <h3>{project.title}</h3>
            <p>{project.description}</p>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  h2 {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 300;
    letter-spacing: -0.02em;
    margin-top: 1rem;
    margin-bottom: 4rem;
  }

  .project-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2px;
  }

  .project-card {
    display: block;
    background: var(--bg-2);
    overflow: hidden;
    transition: background 0.2s;
  }

  .project-card:hover {
    background: #1a1a1a;
  }

  .project-card:hover .image-placeholder {
    border-color: var(--accent-dim);
  }

  .project-image {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--bg);
  }

  .project-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .project-card:hover img {
    transform: scale(1.04);
  }

  .image-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px dashed var(--border);
    transition: border-color 0.2s;
  }

  .image-placeholder span {
    font-family: var(--font-mono);
    font-size: 2rem;
    color: var(--border);
    letter-spacing: 0.1em;
  }

  .project-info {
    padding: 1.5rem;
  }

  .project-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.5rem;
  }

  .category {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.15em;
    color: var(--accent);
    text-transform: uppercase;
  }

  .year {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--muted);
  }

  h3 {
    font-size: 1.1rem;
    font-weight: 400;
    margin-bottom: 0.5rem;
  }

  p {
    font-size: 0.875rem;
    color: var(--muted);
    line-height: 1.6;
  }

  @media (max-width: 768px) {
    .project-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
