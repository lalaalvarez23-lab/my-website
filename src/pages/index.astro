---
import Layout from '../layouts/Layout.astro';

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');

const images = [
  `${base}images/01.jpg`,
  `${base}images/02.jpg`,
  `${base}images/03.jpg`,
  `${base}images/04.jpg`,
  `${base}images/05.jpg`,
  `${base}images/06.jpg`,
  `${base}images/07.jpg`,
  `${base}images/08.jpg`,
  `${base}images/09.jpg`,
  `${base}images/10.jpg`,
  `${base}images/11.jpg`,
  `${base}images/12.jpg`,
  `${base}images/13.jpg`,
  `${base}images/14.jpg`,
  `${base}images/15.jpg`,
  `${base}images/16.jpg`,
];
---

<Layout title="Laura Alvarez">
  <div class="splash">
    <div class="slideshow">
      {images.map((src, i) => (
        <img src={src} alt="" class="slide" />
      ))}
    </div>

    <div class="overlay" />

    <a href={`${base}work`} class="work-btn">WORK</a>
  </div>
</Layout>

<script>
  const slides = Array.from(document.querySelectorAll<HTMLElement>('.slide'));

  // shuffle order, always start with image 11 (index 10)
  const rest = slides.map((_, i) => i).filter(i => i !== 10 && i !== 8).sort(() => Math.random() - 0.5);
  const order = [10, 8, ...rest];
  let step = 0;

  slides[order[0]].classList.add('active');

  setInterval(() => {
    slides[order[step]].classList.remove('active');
    step = (step + 1) % order.length;
    slides[order[step]].classList.add('active');
  }, 10000);
</script>

<style>
  .splash {
    position: fixed;
    inset: 0;
    overflow: hidden;
    background: #111;
  }

  .slideshow {
    position: absolute;
    inset: 0;
  }

  .slide {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 1.2s ease;
  }

  .slide.active {
    opacity: 1;
  }

  .overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.3);
  }

  .work-btn {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    color: #fff;
    font-size: 12px;
    letter-spacing: 0.25em;
    font-family: var(--font);
    border: 1px solid rgba(255, 255, 255, 0.7);
    padding: 16px 48px;
    transition: background 0.2s, border-color 0.2s;
  }

  .work-btn:hover {
    background: rgba(255, 255, 255, 0.12);
    border-color: #fff;
  }
</style>
