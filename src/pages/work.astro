---
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');

const projects = [
  {
    title: 'Trespass',
    category: 'Short Film',
    year: '2026',
    image: `${base}images/POSTER_TRESPASS.png`,
    link: `${base}projects/trespass`,
  },
  {
    title: 'Durex',
    category: 'Spec Ad',
    year: '2026',
    image: `${base}images/POSTER%20SPERMANIA.png`,
    link: `${base}projects/durex`,
  },
  {
    title: 'Desierto',
    category: 'Music Video',
    year: '2026',
    image: `${base}images/POSTER%20DESIERTO.png`,
    link: `${base}projects/desierto`,
  },
];
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Work — Laura Alvarez</title>
  <meta name="description" content="Work by Laura Alvarez — Producer and Director based in Los Angeles." />
  <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Chivo:wght@300;400;500&family=Chivo+Mono:wght@300;400&display=swap" rel="stylesheet" />
</head>
<body>

  <div class="scene">

    <!-- Back to home -->
    <a class="back-home" href={base} aria-label="Back to home">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M19 12H5M5 12l7-7M5 12l7 7"/>
      </svg>
    </a>

    <!-- Corner bracket marks -->
    <div class="corner corner-tl"><svg viewBox="0 0 12 12"><path d="M1 6 L1 1 L6 1"/></svg></div>
    <div class="corner corner-tr"><svg viewBox="0 0 12 12"><path d="M1 6 L1 1 L6 1"/></svg></div>
    <div class="corner corner-bl"><svg viewBox="0 0 12 12"><path d="M1 6 L1 1 L6 1"/></svg></div>
    <div class="corner corner-br"><svg viewBox="0 0 12 12"><path d="M1 6 L1 1 L6 1"/></svg></div>

    <!-- Custom cursor -->
    <div class="cursor" id="cursor">
      <div class="cursor-plus"></div>
    </div>

    <!-- Nav bar -->
    <nav class="nav-top" aria-label="Main navigation">
      <div class="nav-bar">
        <a class="nav-item active" href={`${base}work`}>Work</a>
        <a class="nav-item" href={`${base}about`}>About</a>
        <a class="nav-item contact" href={`${base}contact`}>Contact</a>
        <button class="nav-item toggle" id="themeToggle" aria-label="Toggle light/dark mode">
          <svg id="iconMoon" viewBox="0 0 24 24"><path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/></svg>
          <svg id="iconSun" viewBox="0 0 24 24" style="display:none;">
            <circle cx="12" cy="12" r="4"/>
            <line x1="12" y1="2" x2="12" y2="4"/>
            <line x1="12" y1="20" x2="12" y2="22"/>
            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
            <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
            <line x1="2" y1="12" x2="4" y2="12"/>
            <line x1="20" y1="12" x2="22" y2="12"/>
            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
            <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
          </svg>
        </button>
      </div>
    </nav>

    <!-- Project grid -->
    <main>
      {projects.map((project) => (
        <a href={project.link} class="project-card">
          <div class="thumb">
            {project.image
              ? <img src={project.image} alt={project.title} />
              : <div class="placeholder" />
            }
          </div>
          <div class="meta">
            <span class="title-row">
              <span class="title">{project.title}</span>
              {project.badge === 'Coming Soon' && <span class="badge-soon">COMING SOON</span>}
            </span>
            <span class="info">
              {project.category}{project.badge === 'Coming Soon' ? '' : `, ${project.year}`}
              {project.badge && project.badge !== 'Coming Soon' ? ` — ${project.badge}` : ''}
            </span>
          </div>
        </a>
      ))}
    </main>

  </div>

  <script>
    const body = document.body;
    const toggleBtn = document.getElementById('themeToggle');
    const iconMoon = document.getElementById('iconMoon');
    const iconSun = document.getElementById('iconSun');

    function applyTheme(theme) {
      if (theme === 'light') {
        body.classList.add('light');
        iconMoon.style.display = 'none';
        iconSun.style.display = 'block';
      } else {
        body.classList.remove('light');
        iconMoon.style.display = 'block';
        iconSun.style.display = 'none';
      }
      localStorage.setItem('theme', theme);
    }

    const saved = localStorage.getItem('theme');
    if (saved) {
      applyTheme(saved);
    } else if (window.matchMedia('(prefers-color-scheme: light)').matches) {
      applyTheme('light');
    }

    toggleBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      applyTheme(body.classList.contains('light') ? 'dark' : 'light');
    });

    const cursor = document.getElementById('cursor');
    if (window.matchMedia('(pointer: fine)').matches) {
      document.addEventListener('mousemove', (e) => {
        cursor.style.left = e.clientX + 'px';
        cursor.style.top  = e.clientY + 'px';
        cursor.style.opacity = '1';
      });
      document.addEventListener('mouseleave', () => {
        cursor.style.opacity = '0';
      });
    }
  </script>

</body>
</html>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html, body { width: 100%; height: 100%; }
  @media (pointer: fine) { *, *::before, *::after { cursor: none !important; } }

  :root {
    --bg:           #1a1710;
    --text-primary: rgba(240,235,224,0.90);
    --text-mid:     rgba(240,235,224,0.62);
    --text-low:     rgba(192,176,144,0.40);
    --text-ghost:   rgba(192,176,144,0.22);
    --border-warm:  rgba(200,186,144,0.13);
    --border-faint: rgba(200,186,144,0.07);
    --nav-bg:       rgba(34,30,18,0.92);
    --font:         'Chivo', sans-serif;
  }

  body.light {
    --bg:           #f7f3ec;
    --text-primary: rgba(26,22,8,0.88);
    --text-mid:     rgba(26,22,8,0.55);
    --text-low:     rgba(26,22,8,0.30);
    --text-ghost:   rgba(26,22,8,0.18);
    --border-warm:  rgba(26,22,8,0.10);
    --border-faint: rgba(26,22,8,0.06);
    --nav-bg:       rgba(247,243,236,0.92);
  }

  .scene {
    min-height: 100%;
    background: var(--bg);
    transition: background 0.6s ease;
    cursor: none;
  }

  /* ─── Back arrow ─────────────────────────────────────── */
  .back-home {
    position: fixed;
    top: 18px;
    left: 18px;
    z-index: 50;
    color: var(--text-low);
    display: flex;
    align-items: center;
    transition: color 0.2s;
  }
  .back-home:hover { color: var(--text-primary); }
  .back-home svg { width: 14px; height: 14px; }

  /* ─── Corner brackets ────────────────────────────────── */
  .corner {
    position: fixed;
    z-index: 15;
    pointer-events: none;
  }
  .corner svg {
    width: 12px; height: 12px;
    stroke: rgba(200,186,144,0.12);
    fill: none;
    stroke-width: 1;
  }
  body.light .corner svg { stroke: rgba(26,22,8,0.1); }
  .corner-tl { top: 18px; left: 18px; }
  .corner-tr { top: 18px; right: 18px; transform: rotate(90deg); }
  .corner-bl { bottom: 18px; left: 18px; transform: rotate(-90deg); }
  .corner-br { bottom: 18px; right: 18px; transform: rotate(180deg); }

  /* ─── Nav bar ────────────────────────────────────────── */
  .nav-top {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 40;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 16px 24px;
    pointer-events: none;
  }

  .nav-bar {
    display: flex;
    align-items: center;
    border-radius: 12px;
    overflow: hidden;
    background: var(--nav-bg);
    border: 0.5px solid var(--border-warm);
    pointer-events: all;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    transition: background 0.6s ease, border-color 0.6s ease;
  }

  .nav-item {
    font-family: var(--font);
    font-size: 10px;
    font-weight: 300;
    color: var(--text-mid);
    padding: 6px 18px;
    text-decoration: none;
    letter-spacing: 0.03em;
    border-right: 0.5px solid var(--border-faint);
    white-space: nowrap;
    display: flex;
    align-items: center;
    cursor: pointer;
    background: none;
    border-top: none;
    border-bottom: none;
    border-left: none;
    transition: color 0.2s;
  }
  .nav-item:last-child { border-right: none; }
  .nav-item:hover, .nav-item.active { color: var(--text-primary); }

  .nav-item.contact {
    background: rgba(200,186,144,0.08);
    color: var(--text-mid);
  }

  .nav-item.toggle {
    padding: 6px 13px;
    color: var(--text-ghost);
  }
  .nav-item.toggle svg {
    width: 10px; height: 10px;
    fill: none; stroke: currentColor;
    stroke-width: 1.5;
    stroke-linecap: round; stroke-linejoin: round;
  }

  /* ─── Project grid ───────────────────────────────────── */
  main {
    min-height: 100svh;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 40px;
    flex-wrap: wrap;
    padding: 80px 24px;
  }

  .project-card {
    display: block;
    width: 260px;
    text-decoration: none;
  }

  .thumb {
    width: 260px;
    aspect-ratio: 2 / 3;
    overflow: hidden;
    background: rgba(200,186,144,0.05);
    margin-bottom: 10px;
  }

  .thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease, opacity 0.3s ease;
  }

  .project-card:hover .thumb img {
    transform: scale(1.03);
    opacity: 0.8;
  }

  .placeholder {
    width: 100%;
    height: 100%;
    background: rgba(200,186,144,0.05);
  }

  .meta {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .title-row {
    display: flex;
    align-items: baseline;
    gap: 8px;
  }

  .title {
    font-family: var(--font);
    font-size: 11px;
    font-weight: 300;
    color: var(--text-primary);
    letter-spacing: 0.02em;
  }

  .badge-soon {
    font-family: var(--font);
    font-size: 9px;
    font-weight: 300;
    color: var(--text-ghost);
    letter-spacing: 0.06em;
  }

  .info {
    font-family: var(--font);
    font-size: 10px;
    font-weight: 300;
    color: var(--text-low);
    letter-spacing: 0.03em;
  }

  /* ─── Custom cursor ──────────────────────────────────── */
  .cursor {
    position: fixed;
    z-index: 100;
    pointer-events: none;
    transform: translate(-50%, -50%);
    opacity: 0;
    transition: opacity 0.15s ease;
  }
  .cursor-plus {
    width: 20px; height: 20px;
    position: relative;
  }
  .cursor-plus::before {
    content: '';
    position: absolute;
    top: 50%; left: 0; right: 0;
    height: 0.5px;
    background: rgba(200,186,144,0.65);
    transform: translateY(-50%);
  }
  .cursor-plus::after {
    content: '';
    position: absolute;
    left: 50%; top: 0; bottom: 0;
    width: 0.5px;
    background: rgba(200,186,144,0.65);
    transform: translateX(-50%);
  }
  body.light .cursor-plus::before,
  body.light .cursor-plus::after {
    background: rgba(26,22,8,0.45);
  }

  /* ─── Mobile ─────────────────────────────────────────── */
  @media (max-width: 768px) {
    main { gap: 48px; }
    .project-card, .thumb { width: min(260px, 78vw); }
    .nav-item { padding: 6px 12px; font-size: 10px; }
  }
</style>
